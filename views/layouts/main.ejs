<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🍲 Smart Food Recommendation System</title>

  <!-- Bootstrap 5.3 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

  <!-- Select2 (for better dropdowns in forms/modals) -->
  <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <!-- Custom attractive styles -->
  <style>
    :root {
      --primary:    #28a745;     /* success green - food fresh */
      --primary-d:  #218838;
      --accent:     #fd7e14;     /* orange - warm, appetizing */
      --dark:       #1e293b;
      --dark-l:     #334155;
      --light:      #f8fafc;
      --gray:       #64748b;
      --sidebar-w:  260px;
    }

    body {
      background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
      min-height: 100vh;
      font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      color: var(--dark);
    }

    /* Sidebar */
    .sidebar {
      position: fixed;
      top: 0;
      bottom: 0;
      left: 0;
      width: var(--sidebar-w);
      background: linear-gradient(180deg, var(--dark) 0%, var(--dark-l) 100%);
      color: white;
      transition: transform 0.3s ease;
      z-index: 1000;
      overflow-y: auto;
    }

    .sidebar-header {
      padding: 1.5rem 1.25rem;
      border-bottom: 1px solid rgba(255,255,255,0.12);
      background: rgba(0,0,0,0.2);
    }

    .sidebar-brand {
      font-size: 1.6rem;
      font-weight: 700;
      color: white;
      text-decoration: none;
    }

    .nav-link {
      color: rgba(255,255,255,0.85) !important;
      padding: 0.75rem 1.25rem;
      border-radius: 0.5rem;
      margin: 0.25rem 0.75rem;
      transition: all 0.25s;
    }

    .nav-link:hover,
    .nav-link.active {
      background: rgba(255,255,255,0.12);
      color: white !important;
      transform: translateX(6px);
    }

    .nav-link i {
      width: 24px;
      text-align: center;
      margin-right: 12px;
      font-size: 1.15rem;
    }

    .sidebar-footer {
      position: absolute;
      bottom: 1.5rem;
      width: 100%;
      padding: 0 1.25rem;
    }

    /* Main content area */
    .main-content {
      margin-left: var(--sidebar-w);
      padding: 1.5rem;
      transition: margin-left 0.3s;
    }

    /* Mobile behavior */
    @media (max-width: 992px) {
      .sidebar {
        transform: translateX(-100%);
      }
      .sidebar.show {
        transform: translateX(0);
      }
      .main-content {
        margin-left: 0 !important;
      }
    }

    /* Cards & food items */
    .food-card {
      border: none;
      border-radius: 1rem;
      overflow: hidden;
      transition: all 0.3s ease;
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    }

    .food-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 16px 40px rgba(0,0,0,0.12);
    }

    .card-img-top {
      height: 220px;
      object-fit: cover;
    }

    .badge {
      font-size: 0.9rem;
      padding: 0.5em 1em;
    }

    h3, h5 {
      font-weight: 700;
      color: var(--dark);
    }

    /* Buttons */
    .btn-primary   { background: var(--primary); border-color: var(--primary); }
    .btn-primary:hover { background: var(--primary-d); border-color: var(--primary-d); }
    .btn-accent    { background: var(--accent); border-color: var(--accent); color: white; }
  </style>
</head>
<body>

  <!-- LEFT SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <a href="/" class="sidebar-brand">🍲 Smart Food</a>
    </div>

    <ul class="nav flex-column mt-3">
      <% if (locals.user) { %>

        <% if (locals.user.role === 'admin') { %>
          <li class="nav-item">
            <a class="nav-link <%= page === 'manage-foods' ? 'active' : '' %>" href="/admin/manage-foods">
              <i class="bi bi-grid-1x2-fill"></i> Manage Foods
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= page === 'add-food' ? 'active' : '' %>" href="/admin/add-food">
              <i class="bi bi-plus-circle-fill"></i> Add New Food
            </a>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link <%= page === 'foods' ? 'active' : '' %>" href="/foods">
              <i class="bi bi-heart-fill"></i> Recommended For Me
            </a>
          </li>
        <% } %>

        <li class="nav-item mt-4">
          <a class="nav-link" href="/logout">
            <i class="bi bi-box-arrow-right"></i> Logout
          </a>
        </li>

      <% } else { %>
        <li class="nav-item">
          <a class="nav-link" href="/login">
            <i class="bi bi-box-arrow-in-right"></i> Login
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/register">
            <i class="bi bi-person-plus-fill"></i> Register
          </a>
        </li>
      <% } %>
    </ul>

    <div class="sidebar-footer">
      <small class="text-white-50">© <%= new Date().getFullYear() %> Smart Food</small>
    </div>
  </aside>

  <!-- Mobile toggle button -->
  <button class="btn btn-primary d-lg-none position-fixed m-3" style="z-index: 1100; top:0; left:0;" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebar" aria-controls="sidebar">
    <i class="bi bi-list fs-3"></i>
  </button>

  <!-- MAIN CONTENT -->
  <main class="main-content">
    <div class="container-fluid">

      <!-- Page content from other views -->
      <%- body %>

    </div>
  </main>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

  <script>
    $(document).ready(function(){
      $('.select2').select2({
        dropdownParent: $(this).closest('.modal') || $('body')
      });
    });
  </script>
</body>
</html>