<div class="register-page min-vh-100 d-flex align-items-center" 
     style="background: linear-gradient(rgba(0,0,0,0.58), rgba(0,0,0,0.68)), 
            url('https://thumbs.dreamstime.com/z/breathtaking-aerial-views-gourmet-meals-delicious-food-photography-captured-above-inspiration-experience-351048369.jpg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;">

  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">

        <!-- Glassmorphism Card -->
        <div class="card register-card shadow-xl border-0 overflow-hidden animate__animated animate__fadeInUp"
             style="background: rgba(255, 255, 255, 0.14);
                    backdrop-filter: blur(14px);
                    -webkit-backdrop-filter: blur(14px);
                    border-radius: 1.6rem;
                    border: 1px solid rgba(255,255,255,0.20);">

          <div class="card-body p-4 p-md-5 text-white">

            <h3 class="text-center mb-3 fw-bold">Join Smart Food</h3>
            <p class="text-center text-white-75 mb-4">Create your profile & discover personalized meals</p>

            <form method="POST" action="/register">
              <div class="mb-3">
                <input class="form-control form-control-lg bg-white bg-opacity-25 border-0 text-white placeholder-white"
                       name="name" placeholder="Full Name" required
                       style="border-radius: 0.9rem; backdrop-filter: blur(5px);">
              </div>

              <div class="mb-3">
                <input type="email" class="form-control form-control-lg bg-white bg-opacity-25 border-0 text-white placeholder-white"
                       name="email" placeholder="Email address" required
                       style="border-radius: 0.9rem; backdrop-filter: blur(5px);">
              </div>

              <div class="mb-3">
                <select name="role" class="form-select form-select-lg bg-white bg-opacity-25 border-0 text-white"
                        style="border-radius: 0.9rem; backdrop-filter: blur(5px);">
                  <option value="" disabled selected>Select your role</option>
                  <option value="customer">Customer</option>
                  <option value="admin">Admin</option>
                </select>
              </div>

              <div class="mb-3">
                <select name="religion" class="form-select form-select-lg bg-white bg-opacity-25 border-0 text-white"
                        style="border-radius: 0.9rem; backdrop-filter: blur(5px);">
                  <option value="" disabled selected>Your Religion</option>
                  <option>Muslim</option>
                  <option>Christian</option>
                  <option>Adventist</option>
                </select>
              </div>

              <div class="mb-3">
                <select name="tribe" class="form-select form-select-lg bg-white bg-opacity-25 border-0 text-white"
                        style="border-radius: 0.9rem; backdrop-filter: blur(5px);">
                  <option value="" disabled selected>Your Tribe</option>
                  <option>Sukuma</option>
                  <option>Maasai</option>
                  <option>Nyakyusa</option>
                  <option>Makonde</option>
                  <option>Malila</option>
                  <option>Safwa</option>
                  <option>Chagga</option>
                  <option>Hehe</option>
                  <option>Haya</option>
                  <option>Zaramo</option>
                </select>
              </div>

              <div class="mb-3">
                <input type="number" class="form-control form-control-lg bg-white bg-opacity-25 border-0 text-white placeholder-white"
                       name="age" placeholder="Your Age" required
                       style="border-radius: 0.9rem; backdrop-filter: blur(5px);">
              </div>

              <div class="mb-4">
                <input type="password" class="form-control form-control-lg bg-white bg-opacity-25 border-0 text-white placeholder-white"
                       name="password" placeholder="Create Password" required
                       style="border-radius: 0.9rem; backdrop-filter: blur(5px);">
              </div>

              <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow"
                      style="border-radius: 0.9rem; background: linear-gradient(90deg, #007bff, #00aaff); border: none;">
                Create Account
              </button>
            </form>

            <p class="text-center mt-4 mb-0">
              Already have an account? 
              <a href="/login" class="text-warning fw-bold text-decoration-none">Login here</a>
            </p>

          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- Animate.css CDN (add to layout head if not already there) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

<style>
  .register-page {
    position: relative;
  }
  .register-card {
    transition: all 0.4s ease;
  }
  .register-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 25px 50px rgba(0,0,0,0.45) !important;
  }
  ::placeholder, select option {
    color: rgba(52, 0, 130, 0.75) !important;
  }
  select option:disabled {
    color: rgba(53, 183, 195, 0.5) !important;
  }
</style>