<div class="login-page min-vh-100 d-flex align-items-center" 
     style="background: linear-gradient(rgba(0,0,0,0.55), rgba(0,0,0,0.65)), 
            url('https://images.unsplash.com/photo-1606857521015-7f9fcf423740?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;">

  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-5 col-lg-4">

        <!-- Glassmorphism Card -->
        <div class="card login-card shadow-lg border-0 overflow-hidden animate__animated animate__fadeInUp"
             style="background: rgba(255, 255, 255, 0.12);
                    backdrop-filter: blur(12px);
                    -webkit-backdrop-filter: blur(12px);
                    border-radius: 1.5rem;
                    border: 1px solid rgba(255,255,255,0.18);">

          <div class="card-body p-4 p-md-5 text-white">

            <h3 class="text-center mb-4 fw-bold">Welcome Back</h3>
            <p class="text-center text-white-75 mb-4">Sign in to discover foods made for you</p>

            <form method="POST" action="/login">
              <div class="mb-3">
                <input type="email" class="form-control form-control-lg bg-white bg-opacity-25 border-0 text-white placeholder-white"
                       name="email" placeholder="Email address" required
                       style="border-radius: 0.8rem; backdrop-filter: blur(4px);">
              </div>

              <div class="mb-4">
                <input type="password" class="form-control form-control-lg bg-white bg-opacity-25 border-0 text-white placeholder-white"
                       name="password" placeholder="Password" required
                       style="border-radius: 0.8rem; backdrop-filter: blur(4px);">
              </div>

              <button type="submit" class="btn btn-success btn-lg w-100 fw-bold shadow"
                      style="border-radius: 0.8rem; background: linear-gradient(90deg, #28a745, #34d058);">
                Login
              </button>
            </form>

            <p class="text-center mt-4 mb-0">
              Don't have an account? 
              <a href="/register" class="text-warning fw-bold text-decoration-none">Register here</a>
            </p>

          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- Optional: Add Animate.css for fade-in (via CDN in layout or here) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

<style>
  .login-page {
    position: relative;
  }
  .login-card {
    transition: all 0.4s ease;
  }
  .login-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4) !important;
  }
  ::placeholder {
    color: rgba(255,255,255,0.7) !important;
  }
</style>